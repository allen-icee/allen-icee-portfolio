rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Public read access for all collections
    match /projects/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == "ADMIN_UID_HERE";
    }

    match /experience/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == "ADMIN_UID_HERE";
    }

    match /skills/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == "ADMIN_UID_HERE";
    }

    match /artworks/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == "ADMIN_UID_HERE";
    }

    match /library/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == "ADMIN_UID_HERE";
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
