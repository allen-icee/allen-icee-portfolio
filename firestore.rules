rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check admin auth
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'alleniceedequiros@gmail.com';
    }

    match /projects/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /experience/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /skills/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /skillCategories/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /artworks/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /certificates/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /contactInfo/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
